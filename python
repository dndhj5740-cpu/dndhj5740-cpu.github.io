@app.route("/")
def index():
    return render_template_string(HTML_TEMPLATE)

@app.route("/send", methods=["POST"])
def send():
    phone = request.form.get("phone")
    count = int(request.form.get("count"))
    if count <= 0:
        return "发送次数为0，终止执行"

    try:
        response = requests.post(
            url=API_URL,
            headers=HEADERS,
            cookies=COOKIES,
            data=POST_DATA.strip(),
            timeout=15
        )
        output = f"""
目标手机号：{phone}
发送次数：{count}
HTTP状态码：{response.status_code}
返回内容：
{response.text}
"""
        print(output)
        return output
    except Exception as e:
        err = f"请求出错：{str(e)}"
        print(err)
        return err

if __name__ == "__main__":
    app.run(debug=True)
