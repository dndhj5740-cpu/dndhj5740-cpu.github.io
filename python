}

COOKIES = {
    "BAIDUID": "1146F46345FF5F2DEB0392A9A4D6872C:FG=1",
    "fuid": "687be74252dd95d88613ab30d0e7989a"
}

# ⚠️ 一次性表单，现在已经失效！你需要替换成新抓包的完整表单字符串
POST_DATA = """在这里粘贴抓包完整表单参数"""

# ==================== 内嵌HTML页面（和你截图一模一样的界面） ====================
HTML_TEMPLATE = """
